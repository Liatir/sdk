{
  "name": "@liatir/api",
  "version": "1.9.11",
  "description": "Node.js API bindings for Liatir — gives .lia plugins access to the full Liatir.* bridge",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "type": "module",
  "files": [
    "dist"
  ],
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "build:bundle": "tsup",
    "dev": "tsc -p tsconfig.json --watch",
    "prepublishOnly": "npm run build:bundle"
  },
  "devDependencies": {
    "tsup": "^8.0.0",
    "typescript": "^5.0.0"
  }
}
